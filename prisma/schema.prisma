generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Membership {
  FREE
  BASIC
  PREMIUM
  VIP
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum DivinationMethod {
  MANUAL
  TIME
  NUMBER
  RANDOM
}

enum PaymentType {
  MEMBERSHIP
  READING
  RECHARGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ReportType {
  BAZI_READING
  DAILY_FORTUNE
  MONTHLY_FORTUNE
  YEARLY_FORTUNE
  CUSTOM
}

model User {
  id                  String          @id @default(cuid())
  email               String?         @unique
  phone               String?         @unique
  wechatId            String?         @unique @map("wechat_id")
  name                String?
  avatar              String?

  role                UserRole        @default(USER)
  isBanned            Boolean         @default(false) @map("is_banned")
  bannedAt            DateTime?       @map("banned_at")
  bannedReason        String?         @map("banned_reason")
  isGuest             Boolean         @default(false) @map("is_guest")
  guestExpiresAt      DateTime?       @map("guest_expires_at")

  membership          Membership      @default(FREE)
  membershipExpiresAt DateTime?       @map("membership_expires_at")

  readingCount        Int             @default(0) @map("reading_count")
  lastReadingAt       DateTime?       @map("last_reading_at")

  profiles            BaziProfile[]
  baziReadings        BaziReading[]
  liuyaoReadings      LiuyaoReading[]
  reports             Report[]
  payments            Payment[]
  sessions            UserSession[]

  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("users")
}

model OperationLog {
  id            String    @id @default(cuid())
  module        String
  action        String
  level         String    @default("INFO")
  actorId       String?   @map("actor_id")
  targetType    String?   @map("target_type")
  targetId      String?   @map("target_id")
  message       String?
  payload       Json?
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([module, createdAt])
  @@index([level, createdAt])
  @@map("operation_logs")
}

model BaziProfile {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  gender      Gender
  birthDate   DateTime       @map("birth_date")
  birthTime   String         @map("birth_time")
  birthPlace  String         @map("birth_place")
  country     String?
  province    String?
  city        String?
  district    String?
  longitude   Float?
  latitude    Float?

  isDefault   Boolean        @default(false) @map("is_default")
  tags        String[]       @default([])
  notes       String?

  readings    BaziReading[]
  reports     Report[]

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([userId, isDefault])
  @@map("bazi_profiles")
}

model BaziReading {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileId     String?     @map("profile_id")
  profile       BaziProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  name          String
  gender        Gender
  birthDate     DateTime    @map("birth_date")
  birthTime     String      @map("birth_time")
  birthPlace    String      @map("birth_place")
  country       String?
  province      String?
  city          String?
  district      String?
  longitude     Float?
  latitude      Float?

  baziData      Json        @map("bazi_data")
  daYun         Json        @map("da_yun")
  liuNian       Json        @map("liu_nian")
  aiAnalysis    Json?       @map("ai_analysis")
  baseScores    Json?       @map("base_scores")
  klineData     Json?       @map("kline_data")

  isFavorite    Boolean     @default(false) @map("is_favorite")
  notes         String?

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  reports       Report[]

  @@index([userId])
  @@index([profileId])
  @@index([birthDate])
  @@map("bazi_readings")
}

model LiuyaoReading {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  question      String
  method        DivinationMethod

  guaXiang      Json        @map("gua_xiang")
  yaoList       Json        @map("yao_list")
  aiAnalysis    Json?       @map("ai_analysis")

  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@map("liuyao_readings")
}

model Report {
  id            String      @id @default(cuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileId     String?     @map("profile_id")
  profile       BaziProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  readingId     String?     @map("reading_id")
  reading       BaziReading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  title         String
  reportType    ReportType  @map("report_type")
  summary       String?
  content       Json
  meta          Json?
  isArchived    Boolean     @default(false) @map("is_archived")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([reportType])
  @@map("reports")
}

model Payment {
  id              String        @id @default(cuid())
  orderNo         String        @unique @default(cuid()) @map("order_no")
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("CNY")

  type            PaymentType
  status          PaymentStatus @default(PENDING)

  provider        String
  providerOrderId String?       @map("provider_order_id")

  membershipType  Membership?   @map("membership_type")
  readingId       String?       @map("reading_id")

  callbackPayload Json?         @map("callback_payload")

  paidAt          DateTime?     @map("paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([orderNo])
  @@map("payments")
}

model UserSession {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId      String    @map("device_id")
  deviceType    String    @map("device_type")
  deviceName    String?   @map("device_name")

  lastActiveAt  DateTime  @default(now()) @map("last_active_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("user_sessions")
}

model Config {
  id            String    @id @default(cuid())
  key           String    @unique
  value         Json
  description   String?
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("configs")
}

model AiLog {
  id            String    @id @default(cuid())
  userId        String?   @map("user_id")

  provider      String
  model         String

  inputTokens   Int       @map("input_tokens")
  outputTokens  Int       @map("output_tokens")
  cost          Decimal   @db.Decimal(10, 6)

  requestType   String    @map("request_type")
  latencyMs     Int       @map("latency_ms")

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("ai_logs")
}
